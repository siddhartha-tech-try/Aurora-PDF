{
  "name": "aurora-pdf",
  "version": "0.1.0",
  "description": "A production-oriented TypeScript PDF generation and manipulation library.",
  "type": "module",
  "license": "MIT",
  "author": "Aurora PDF Maintainers",
  "homepage": "https://example.com/aurora-pdf",
  "repository": {
    "type": "git",
    "url": "https://example.com/aurora-pdf.git"
  },
  "keywords": [
    "pdf",
    "pdf-generation",
    "html-to-pdf",
    "markdown-to-pdf",
    "typescript",
    "pdfkit",
    "playwright"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "aurora-pdf": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "node -e \"import('node:fs/promises').then(fs=>fs.rm('dist',{recursive:true,force:true}))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "examples": "npm run build && node examples/run-all.mjs",
    "benchmark": "npm run build && node benchmarks/large-document.mjs",
    "docs": "typedoc",
    "verify": "npm run build && npm test && npm run examples && npm run benchmark && npm run docs",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@pdfsmaller/pdf-encrypt": "^1.0.2",
    "commander": "^14.0.2",
    "handlebars": "^4.7.8",
    "markdown-it": "^14.1.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "playwright": "^1.60.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@types/pdfkit": "^0.17.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.14",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20.11"
  }
}
